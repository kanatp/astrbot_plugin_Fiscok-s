{
  "meme_config": {
    "describe" : "meme发送/获取相关配置",
    "type" : "object",
    "items" : {
      "meme_available" : {
        "describe" : "是否启用表情包功能",
        "type" : "bool",
        "default" : false
      },
      "meme_cache_size" : {
        "describe" : "表情包缓存大小，单位为条",
        "type" : "int",
        "default" : 200
      },
      "emoji_learn_max" : {
        "describe" : "bot偷取群友meme的最大概率（表情包数量为0时）",
        "type" : "float",
        "default" : 0.7
      },
      "emoji_learn_min" : {
        "describe" : "bot偷取群友meme的最小概率（表情包数量达到上限时）",
        "type" : "float",
        "default" : 0.02
      },
      "emoji_attach_positive" : {
        "describe" : "bot发言时携带meme的概率",
        "type" : "float",
        "default" : 0.7
      },
      "llm_provider_id" : {
        "describe" : "用于表情包描述生成的LLM Provider",
        "type" : "string",
        "default" : "",
        "_special" : "select_provider",
        "hint" : "留空时使用第一个可用的模型"
      },
      "placeholder_tag" : {
        "describe" : "LLM回复中表情包占位符的标签名",
        "type" : "string",
        "default" : "meme"
      }
    }
  },
  "twitter_subscription_config": {
    "describe": "twitter订阅相关配置",
    "type": "object",
    "items": {
      "twitter_subscription_available": {
        "describe": "是否启动twitter订阅功能",
        "type": "bool",
        "default": false
      },
      "twitter_push_cache_size": {
        "describe": "twitter推送的缓存大小，单位为条",
        "type": "int",
        "default": 100
      },
      "twitter_push_time": {
        "describe": "twitter推送的时间",
        "type": "list",
        "default": [
          "08:00",
          "13:00",
          "19:00",
          "23:00"
        ]
      },
      "twitter_push_cache_time": {
        "describe": "更新推特订阅缓存的时间间隔，单位为小时",
        "type": "int",
        "default": 1
      },
      "rssHub_url": {
        "describe": "rssHub接口地址",
        "type": "string",
        "default": "127.0.0.1"
      },
      "rssHub_port": {
        "describe": "rssHub接口端口",
        "type": "int",
        "default": 1200
      }
    }
  }
}